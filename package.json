{
  "publisher": "htb-fast-food-workers",
  "name": "plylf",
  "displayName": "PLYLF",
  "description": "leetcode problem exporter AKA Practice Leetcode You Lazy Freak",
  "version": "0.0.6",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "resources/icons/lcpaint.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "leet.browse",
        "title": "Browse Problems"
      },
      {
        "command": "leet.run-solution",
        "title": "Run Leet Solution"
      },
      {
        "command": "leet.select-language",
        "title": "Language"
      },
      {
        "command": "leet.import-problem",
        "title": "Import this problem",
        "icon": "$(desktop-download)"
      },
      {
        "command": "leet.create-test-cases",
        "title": "Create Test Cases",
        "icon": "$(thinking)"
      },
      {
        "command": "leet.page-down",
        "title": "Down",
        "icon": "$(chevron-down)"
      },
      {
        "command": "leet.page-up",
        "title": "Up",
        "icon": "$(chevron-up)"
      },
      {
        "command": "leet.set-filter-hard",
        "title": "Hard",
        "icon": "$(star-full)"
      },
      {
        "command": "leet.set-filter-med",
        "title": "Medium",
        "icon": "$(star-half)"
      },
      {
        "command": "leet.set-filter-easy",
        "title": "Easy",
        "icon": "$(star-empty)"
      },
      {
        "command": "leet.toggle-sort",
        "title": "Toggle Sort Order",
        "icon": "$(arrow-swap)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leet-sidebar",
          "title": "Browse Problems",
          "icon": "resources/icons/leet.png"
        }
      ],
      "panel": [
        {
          "id": "leet-panel",
          "title": "Problem Description",
          "icon": "resources/icons/leet.png"
        }
      ]
    },
    "views": {
      "leet-sidebar": [
        {
          "id": "leet-browse-view",
          "name": "All",
          "icon": "resources/icons/leet.png"
        }
      ],
      "leet-panel": [
        {
          "id": "leet-run-view",
          "name": "Run Solution",
          "type": "webview",
          "icon": "resources/icons/leet.png"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "leet.import-problem",
          "when": "viewItem == importable",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "leet.create-test-cases",
          "when": "view == leet-run-view",
          "group": "navigation"
        },
        {
          "command": "leet.toggle-sort",
          "when": "view == leet-browse-view",
          "group": "navigation@1"
        },
        {
          "command": "leet.set-filter-hard",
          "when": "view == leet-browse-view",
          "group": "navigation@4"
        },
        {
          "command": "leet.set-filter-med",
          "when": "view == leet-browse-view",
          "group": "navigation@3"
        },
        {
          "command": "leet.set-filter-easy",
          "when": "view == leet-browse-view",
          "group": "navigation@2"
        }
      ]
    },
    "colors": [
      {
        "id": "leet.lowacceptance",
        "description": "text color for low acceptance rate",
        "defaults": {
          "light": "#C22402",
          "dark": "#D93B18"
        }
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test",
    "setup": "node scripts/generate.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@leetnotion/leetcode-api": "^1.10.0",
    "@vscode/codicons": "^0.0.45"
  }
}
