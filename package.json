{
  "name": "plylf",
  "displayName": "PLYLF",
  "description": "leetcode problem exporter AKA Practice Leetcode You Lazy Freak",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "leet.browse",
        "title": "Browse Problems"
      },
      {
        "command": "leet.run_solution",
        "title": "Run Leet Solution"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leet-sidebar",
          "title": "Browse Problems",
          "icon": "resources/icons/leet.svg"
        }
      ],
      "panel": [
        {
          "id": "leet-panel",
          "title": "Test Solution",
          "icon": "resources/icons/leet.svg"
        }
      ]
    },
    "views": {
      "leet-sidebar": [
        {
          "id": "leet-browse-view",
          "name": "All",
          "icon": "resources/icons/leet.svg"
        }
      ],
      "leet-panel": [
        {
          "id": "leet-run-view",
          "name": "Run Solution",
          "icon": "resources/icons/leet.svg"
        }
      ]
    },
    "colors": [
      {
        "id": "leet.lowacceptance",
        "description": "text color for low acceptance rate",
        "defaults": {
          "light": "#C22402",
          "dark": "#D93B18"
        }
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@leetnotion/leetcode-api": "^1.10.0"
  }
}
