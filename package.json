{
  "name": "htb-lc",
  "displayName": "Leet Code Importer",
  "description": "leetcode problem exporter",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:leet-browse-view"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "leet.browse",
        "title": "Browse Problems"
      },
      {
        "command": "leet.run_solution",
        "title": "Run Leet Solution"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leet-sidebar",
          "title": "Browse Problems",
          "icon": "resources/icons/leet.svg"
        }
      ],
      "panel": [
        {
          "id": "leet-panel",
          "title": "Test Solution",
          "icon": "resources/icons/leet.svg"
        }
      ]
    },
    "views": {
      "leet-sidebar": [
        {
          "id": "leet-browse-view",
          "name": "All",
          "icon": "resources/icons/leet.svg"
        }
      ],
      "leet-panel": [
        {
          "id": "leet-run-view",
          "name": "Run Solution",
          "icon": "resources/icons/leet.svg"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@leetnotion/leetcode-api": "^1.10.0"
  }
}
